# ========================
# LLM Provider
# ========================
# Options: ollama (local) | gemini (cloud)
LLM_PROVIDER=ollama


# ========================
# Embedding / Vectorization Provider
# Options: tfidf | local_dense
# ========================
EMBEDDING_PROVIDER=tfidf

# Local dense embeddings
LOCAL_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# Optional: point to a downloaded local model directory for offline rebuilds
LOCAL_EMBEDDING_MODEL_PATH=
# Optional: true to avoid network fetches and require local model files
LOCAL_EMBEDDING_OFFLINE_ONLY=false


# ========================
# Ollama (local development)
# ========================
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:3b


# ========================
# Ollama (Docker container)
# For Docker Desktop on macOS/Windows, use:
# OLLAMA_BASE_URL=http://host.docker.internal:11434
# ========================


# ========================
# Gemini (cloud / Render)
# ========================
GEMINI_API_KEY=your_key_here
GEMINI_MODEL=gemini-2.5-flash


# ========================
# Redis (optional caching)
# ========================
# Local: redis://127.0.0.1:6379/0
# Docker: redis://redis:6379/0
# Render: use provided internal Redis URL
REDIS_URL=

# Cache TTL (seconds)
RAG_CACHE_TTL_SECONDS=300